---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/tokens.css';
import StateMachineNav from './nav/StateMachineNav.tsx';

interface Props {
  lang: 'en' | 'pt-br';
}

const { lang } = Astro.props;
const isEnglish = lang === 'en';

const content = {
  en: {
    role: 'Open source at Resend',
    bio: "I build web software. Mostly JavaScript, mostly frontend. I care about architecture, developer experience, and helping teams ship fast without trading away quality. Lately I write about the invisible parts of software, the pieces that decide whether a codebase stays readable as it grows.",
    lede: "The site is a tree. Hover a branch. Click a node. You are at the root — home.",
    langSwitch: 'Ler em português',
    langSwitchHref: '/pt-br/',
    title: 'Diel Duarte — Open source at Resend',
    description: "Diel Duarte works on open source at Resend. Writes about state charts, XState, code splitting, and the architecture of legible UI.",
  },
  'pt-br': {
    role: 'Open source na Resend',
    bio: "Construo software para a web. Principalmente JavaScript, principalmente frontend. Me importo com arquitetura, experiência de desenvolvimento e em ajudar times a entregar rápido sem abrir mão da qualidade. Ultimamente escrevo sobre as partes invisíveis do software, o que decide se um codebase continua fazendo sentido conforme cresce.",
    lede: "O site é uma árvore. Passe o mouse num nó. Clique num nó. Você está na raiz — home.",
    langSwitch: 'Read in English',
    langSwitchHref: '/',
    title: 'Diel Duarte — Open source na Resend',
    description: "Diel Duarte trabalha com open source na Resend. Escreve sobre state charts, XState, code splitting e a arquitetura de UIs legíveis.",
  },
};

const t = content[lang];

const socials = [
  { label: 'GitHub', href: 'https://github.com/dielduarte', path: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dielduarte/', path: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z' },
  { label: 'Twitter', href: 'https://twitter.com/diel_duarte', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.title}</title>
    <meta name="description" content={t.description} />
    <link rel="alternate" hreflang={isEnglish ? 'pt-br' : 'en'} href={t.langSwitchHref} />

    <style is:global>
      :root { color-scheme: dark; }

      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--n-0);
        color: var(--n-6);
        font-family: var(--font-body);
        font-size: var(--fs-base);
        line-height: var(--lh-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: var(--r-sm);
      }

      .skip-link {
        position: absolute;
        top: var(--s-2);
        left: var(--s-2);
        padding: var(--s-2) var(--s-3);
        background: var(--accent);
        color: var(--n-0);
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        border-radius: var(--r-sm);
        transform: translateY(-200%);
        transition: transform var(--t-3) var(--ease);
        z-index: 1000;
      }
      .skip-link:focus {
        transform: translateY(0);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>

  <body>
    <a class="skip-link" href="#main">
      {isEnglish ? 'Skip to content' : 'Pular para o conteúdo'}
    </a>

    <div class="shell">
      <header class="topbar">
        <a class="lang" href={t.langSwitchHref} hreflang={isEnglish ? 'pt-br' : 'en'}>
          <span aria-hidden="true">/</span> {t.langSwitch}
        </a>
      </header>

      <main id="main" class="hero">
        <div class="col text">
          <p class="mono-note">the site · v2</p>
          <h1>Diel&nbsp;Duarte.</h1>
          <p class="role">{t.role}</p>
          <p class="bio">{t.bio}</p>
          <p class="lede">{t.lede}</p>

          <ul class="socials" aria-label={isEnglish ? 'Links' : 'Redes'}>
            {socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path d={s.path} fill="currentColor" />
                  </svg>
                  <span class="sr-only">
                    {s.label}{isEnglish ? ' (opens in new tab)' : ' (abre em nova aba)'}
                  </span>
                </a>
              </li>
            ))}
            <li>
              <a href="mailto:magdiel.kesller@gmail.com">
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z"/>
                </svg>
                <span class="sr-only">Email</span>
              </a>
            </li>
          </ul>
        </div>

        <div class="col diagram">
          <div class="diagram-frame">
            <StateMachineNav client:load initialState="home" initialLang={lang} />
          </div>
        </div>
      </main>

      <footer class="foot">
        <span>© {new Date().getFullYear()} Diel Duarte</span>
        <span class="foot-sep" aria-hidden="true">·</span>
        <span>{isEnglish ? 'the whole thing is a tree' : 'o site inteiro é uma árvore'}</span>
      </footer>
    </div>

    <style>
      .shell {
        max-width: 1160px;
        margin: 0 auto;
        padding: var(--s-5) var(--s-5) var(--s-6);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.04em;
        color: var(--n-5);
        padding-bottom: var(--s-4);
      }

      .lang {
        color: var(--n-5);
        transition: color var(--t-3) var(--ease);
      }

      .lang:hover { color: var(--n-7); }
      .lang:active { transform: scale(0.97); }

      .hero {
        flex: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
        align-items: center;
        gap: var(--s-6);
        padding: var(--s-6) 0;
      }

      .col.text {
        max-width: 52ch;
      }

      .mono-note {
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 var(--s-4) 0;
      }

      h1 {
        font-family: var(--font-display);
        font-size: clamp(3rem, 6vw + 1rem, var(--fs-4xl));
        line-height: 0.98;
        letter-spacing: -0.035em;
        color: var(--n-7);
        margin: 0 0 var(--s-3) 0;
        font-weight: 600;
      }

      .role {
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        color: var(--accent);
        margin: 0 0 var(--s-5) 0;
        letter-spacing: 0.01em;
      }

      .bio {
        font-size: var(--fs-md);
        line-height: var(--lh-body);
        color: var(--n-6);
        margin: 0 0 var(--s-5) 0;
        max-width: 52ch;
      }

      .lede {
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        line-height: var(--lh-body);
        color: var(--n-5);
        padding: var(--s-3) var(--s-4);
        border-left: 1px dashed var(--n-3);
        margin: 0 0 var(--s-5) 0;
      }

      .socials {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--s-4);
        align-items: center;
      }

      .socials a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: var(--r-full);
        color: var(--n-5);
        transition:
          color var(--t-3) var(--ease),
          background-color var(--t-3) var(--ease),
          transform var(--t-2) var(--ease);
      }

      @media (hover: hover) and (pointer: fine) {
        .socials a:hover {
          color: var(--n-7);
          background-color: color-mix(in oklab, var(--n-7) 6%, transparent);
        }
      }

      .socials a:active { transform: scale(0.92); }
      .socials a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .col.diagram {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .diagram-frame {
        width: 100%;
        max-width: 560px;
        aspect-ratio: 6 / 5;
        position: relative;
      }

      .diagram-frame :global(.smn) {
        width: 100%;
        height: 100%;
        max-width: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .diagram-frame :global(.smn svg) {
        width: 100%;
        height: auto;
      }

      .diagram-frame :global(.smn .hint) {
        justify-content: flex-start;
        font-size: var(--fs-xs);
        color: var(--n-5);
        margin-top: var(--s-3);
      }

      .foot {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        color: var(--n-5);
        padding-top: var(--s-5);
        border-top: 1px dashed var(--n-3);
      }

      .foot-sep { color: var(--n-4); }

      @media (max-width: 820px) {
        .hero {
          grid-template-columns: 1fr;
          gap: var(--s-7);
          padding: var(--s-5) 0;
        }

        .col.diagram { order: -1; }

        .diagram-frame {
          max-width: 420px;
          aspect-ratio: 6 / 5;
          margin: 0 auto;
        }

        .col.text {
          max-width: 100%;
        }
      }

      @media (max-width: 520px) {
        .shell { padding: var(--s-4) var(--s-4) var(--s-5); }
        h1 { font-size: clamp(2.5rem, 10vw, 3.5rem); }
        .bio { font-size: var(--fs-base); }
      }
    </style>
  </body>
</html>
