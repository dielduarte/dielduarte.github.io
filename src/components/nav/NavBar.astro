---
import {
  visibleNodes,
  pathToState,
  langFromPath,
  type NavStateId,
  type Lang,
} from './navMachine';

interface Props {
  currentState?: NavStateId;
  lang?: Lang;
  pathname?: string;
}

const pathname = Astro.props.pathname ?? Astro.url.pathname;
const lang: Lang = Astro.props.lang ?? langFromPath(pathname);
const resolvedState: NavStateId =
  Astro.props.currentState ?? pathToState(pathname);

const visibleIds = new Set(visibleNodes.map((n) => n.id));
const activeId = visibleIds.has(resolvedState) ? resolvedState : null;

// Hub-and-spoke mini graph. Same shape as the home diagram, sized down.
const positions: Record<NavStateId, {
  cx: number;
  cy: number;
  lx: number;
  ly: number;
  anchor: 'start' | 'middle' | 'end';
}> = {
  home:    { cx: 22,  cy: 36, lx: 22,  ly: 60, anchor: 'middle' },
  writing: { cx: 138, cy: 12, lx: 150, ly: 16, anchor: 'start'  },
  about:   { cx: 138, cy: 36, lx: 150, ly: 40, anchor: 'start'  },
  contact: { cx: 138, cy: 60, lx: 150, ly: 64, anchor: 'start'  },
  cases:   { cx: 0,   cy: 0,  lx: 0,   ly: 0,  anchor: 'middle' },
  lab:     { cx: 0,   cy: 0,  lx: 0,   ly: 0,  anchor: 'middle' },
};

const items = visibleNodes.map((n) => ({ ...n, ...positions[n.id] }));
const hub = items.find((n) => n.id === 'home')!;
const spokes = items.filter((n) => n.id !== 'home');

// Shorten edges so they terminate at the dot perimeter, not the centers.
const DOT_R = 4;
const EDGE_GAP = 2;
const edgeSegments = spokes.map((s) => {
  const dx = s.cx - hub.cx;
  const dy = s.cy - hub.cy;
  const len = Math.hypot(dx, dy) || 1;
  const ux = dx / len;
  const uy = dy / len;
  const pad = DOT_R + EDGE_GAP;
  return {
    id: s.id,
    x1: hub.cx + ux * pad,
    y1: hub.cy + uy * pad,
    x2: s.cx - ux * pad,
    y2: s.cy - uy * pad,
  };
});
---

<nav class="smn-bar" aria-label="Site navigation">
  <svg
    viewBox="0 0 224 72"
    width="224"
    height="72"
    role="img"
    aria-label="Site navigation as a tree"
  >
    {edgeSegments.map((e) => (
      <line
        class={`edge e-${e.id}`}
        x1={e.x1}
        y1={e.y1}
        x2={e.x2}
        y2={e.y2}
      />
    ))}

    {items.map((node) => {
      const isActive = node.id === activeId;
      const disabled = node.href === null;
      const href = node.href?.[lang] ?? node.href?.en ?? null;
      const label = isActive
        ? `${node.label} — current state`
        : disabled
        ? `${node.label} — future state`
        : `go to ${node.label}`;
      const groupClass = [
        'node',
        isActive && 'active',
        disabled && 'disabled',
        !isActive && !disabled && 'reachable',
      ]
        .filter(Boolean)
        .join(' ');

      const inner = (
        <>
          <circle class="hit" cx={node.cx} cy={node.cy} r={12} />
          <circle class="dot" cx={node.cx} cy={node.cy} r={4} />
          <text
            class="label"
            x={node.lx}
            y={node.ly}
            text-anchor={node.anchor}
          >
            {node.label}
          </text>
        </>
      );

      if (href && !isActive) {
        return (
          <a
            href={href}
            class={`node-link n-${node.id}`}
            aria-label={label}
          >
            <g class={groupClass} style={`transform-origin:${node.cx}px ${node.cy}px`}>{inner}</g>
          </a>
        );
      }

      return (
        <g
          class={`${groupClass} n-${node.id}`}
          aria-label={label}
          aria-current={isActive ? 'page' : undefined}
          style={`transform-origin:${node.cx}px ${node.cy}px`}
        >
          {inner}
        </g>
      );
    })}
  </svg>

  <span class="sr-only">
    {activeId ? `current state — ${activeId}` : 'no active state'}
  </span>
</nav>

<style>
  .smn-bar {
    --smn-ease: cubic-bezier(0.32, 0.72, 0, 1);
    --smn-t: 200ms;
    display: inline-flex;
    line-height: 0;
    user-select: none;
  }

  .smn-bar svg {
    display: block;
    overflow: visible;
  }

  .edge {
    stroke: var(--n-3);
    stroke-width: 1;
    fill: none;
    transition: stroke var(--smn-t) var(--smn-ease);
  }

  .hit {
    fill: transparent;
    pointer-events: all;
  }

  .node {
    transition: transform var(--smn-t) var(--smn-ease);
  }

  .dot {
    fill: transparent;
    stroke: var(--n-4);
    stroke-width: 1.5;
    transition:
      fill var(--smn-t) var(--smn-ease),
      stroke var(--smn-t) var(--smn-ease);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
    fill: var(--n-5);
    transition: fill var(--smn-t) var(--smn-ease);
  }

  .node.active .dot {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .node.active .label {
    fill: var(--accent);
  }

  .node.disabled .dot {
    stroke-dasharray: 2 2;
  }

  .node.disabled .label {
    opacity: 0.55;
  }

  .node.disabled {
    pointer-events: none;
  }

  .node-link {
    cursor: pointer;
    outline: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .node-link:hover .node.reachable .dot {
      fill: color-mix(in oklab, var(--accent) 22%, transparent);
      stroke: var(--accent);
    }
    .node-link:hover .node.reachable .label {
      fill: var(--n-7);
    }
    .node-link:hover .node.reachable {
      transform: scale(1.18);
    }
  }

  .smn-bar:has(.n-writing:hover) .e-writing,
  .smn-bar:has(.n-writing:focus-visible) .e-writing,
  .smn-bar:has(.n-about:hover) .e-about,
  .smn-bar:has(.n-about:focus-visible) .e-about,
  .smn-bar:has(.n-contact:hover) .e-contact,
  .smn-bar:has(.n-contact:focus-visible) .e-contact {
    stroke: var(--accent);
  }

  .node-link:focus-visible .dot {
    stroke: var(--accent);
    stroke-width: 2;
  }

  .node-link:active .node.reachable {
    transform: scale(0.94);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .edge, .dot, .label, .node { transition: none; }
    .node-link:hover .node.reachable,
    .node-link:active .node.reachable { transform: none; }
  }
</style>
