---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/tokens.css';
import NavBar from '../components/nav/NavBar.astro';
import readingTime from 'reading-time';
import { SEO } from 'astro-seo';
import { format } from 'date-fns';
import fs from 'fs';

const { frontmatter, file } = Astro.props;

const fileText = fs.readFileSync(file, 'utf8');
const stats = readingTime(fileText);

const isEnglish = frontmatter.languageKey === 'en';
const lang: 'en' | 'pt-br' = isEnglish ? 'en' : 'pt-br';

const totalTime = isEnglish
  ? stats.text
  : `${Math.ceil(stats.minutes)} min de leitura`;

const socialImage = Astro.site + frontmatter.socialImage;
const formattedDate = format(
  new Date(frontmatter.date),
  isEnglish ? 'MMMM dd, yyyy' : 'dd MMMM yyyy'
);

const backLabel = isEnglish ? 'Back to writing' : 'Voltar para artigos';
const indexHref = isEnglish ? '/blog/en/' : '/blog/pt-br/';

function normalizeLangLink(raw?: string) {
  if (!raw) return null;
  const withLeading = raw.startsWith('/') ? raw : `/${raw}`;
  const prefixed = withLeading.startsWith('/blog') ? withLeading : `/blog${withLeading}`;
  return prefixed.endsWith('/') ? prefixed : `${prefixed}/`;
}

const langSwitchHref =
  normalizeLangLink(frontmatter.languageLink) ??
  (isEnglish ? '/blog/pt-br/' : '/blog/en/');
const langSwitchLabel = isEnglish ? 'Ler em português' : 'Read in English';
---

<html lang={frontmatter.languageKey}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
      title={frontmatter.title}
      description={frontmatter.description}
      openGraph={{
        basic: {
          title: frontmatter.title,
          type: 'article',
          image: socialImage ?? '',
        },
      }}
      extend={{
        meta: [
          { name: 'twitter:image', content: socialImage },
          { name: 'twitter:title', content: frontmatter.title },
          { name: 'twitter:site', content: '@diel_duarte' },
          { name: 'twitter:card', content: 'summary_large_image' },
          { name: 'twitter:description', content: frontmatter.description },
        ],
      }}
    />

    <style is:global>
      :root { color-scheme: dark; }

      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--n-0);
        color: var(--n-6);
        font-family: var(--font-body);
        font-size: var(--fs-base);
        line-height: var(--lh-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      html { scroll-behavior: smooth; }

      a { color: inherit; text-decoration: none; }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }

      /* Reading progress — GPU-only scaleX */
      .reading-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 100%;
        background: var(--accent);
        z-index: 1000;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 100ms linear;
        will-change: transform;
      }

      /* Article prose — serif, token-driven, tuned for reading */
      .prose {
        font-family: var(--font-prose);
        font-size: 1.0625rem;   /* 17px — comfortable reading zone */
        line-height: 1.65;
        color: var(--n-6);
        max-width: 65ch;
        letter-spacing: -0.003em;
      }

      .prose p {
        margin: 0 0 1.6em 0;
      }

      .prose p:last-child {
        margin-bottom: 0;
      }

      .prose > * + * {
        margin-top: 1.6em;
      }

      .prose strong {
        color: var(--n-7);
        font-weight: 600;
      }

      .prose em { font-style: italic; }

      .prose a {
        color: var(--accent);
        background-image: linear-gradient(currentColor, currentColor);
        background-size: 100% 1px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        transition: color var(--t-3) var(--ease);
      }

      .prose a:hover { color: var(--n-7); }

      .prose h2 {
        font-family: var(--font-display);
        font-size: 1.55rem;
        font-weight: 600;
        color: var(--n-7);
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 2.2em 0 0.6em;
      }

      .prose h3 {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--n-7);
        letter-spacing: -0.015em;
        line-height: 1.25;
        margin: 1.8em 0 0.5em;
      }

      .prose h4 {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--n-7);
        margin: 1.6em 0 0.4em;
      }

      .prose code {
        font-family: var(--font-mono);
        font-size: 0.875em;
      }

      .prose :not(pre) > code {
        background: color-mix(in oklab, var(--accent) 10%, var(--n-1));
        color: color-mix(in oklab, var(--accent) 80%, var(--n-7));
        padding: 0.15em 0.4em;
        border-radius: var(--r-sm);
      }

      .prose pre {
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        line-height: 1.6;
        padding: var(--s-4);
        border-radius: var(--r-md);
        margin: var(--s-5) 0;
        overflow-x: auto;
        background: var(--n-1) !important;
        border: 1px solid var(--n-3);
      }

      .prose pre code {
        background: transparent !important;
        color: inherit;
        padding: 0;
      }

      .prose ul, .prose ol {
        margin: 1.15em 0;
        padding-left: 0;
        list-style: none;
      }

      .prose ul li, .prose ol li {
        position: relative;
        padding-left: 1.4em;
        margin-bottom: 0.5em;
      }

      .prose ul li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 5px;
        height: 5px;
        background: var(--accent);
        border-radius: var(--r-full);
      }

      .prose ol { counter-reset: list-counter; }
      .prose ol li { counter-increment: list-counter; }
      .prose ol li::before {
        content: counter(list-counter);
        position: absolute;
        left: 0;
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        color: var(--accent);
      }

      .prose blockquote {
        margin: var(--s-5) 0;
        padding: var(--s-3) var(--s-4);
        border-left: 2px solid var(--accent);
        background: color-mix(in oklab, var(--accent) 6%, transparent);
        border-radius: 0 var(--r-md) var(--r-md) 0;
        color: var(--n-5);
        font-style: italic;
      }

      .prose blockquote p { margin: 0; }

      .prose img, .prose video {
        max-width: 100%;
        border-radius: var(--r-md);
        margin: var(--s-5) auto;
        display: block;
      }

      .prose hr {
        border: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--n-3), transparent);
        margin: var(--s-6) 0;
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: var(--r-sm);
      }

      .skip-link {
        position: absolute;
        top: var(--s-2);
        left: var(--s-2);
        padding: var(--s-2) var(--s-3);
        background: var(--accent);
        color: var(--n-0);
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        border-radius: var(--r-sm);
        transform: translateY(-200%);
        transition: transform var(--t-3) var(--ease);
        z-index: 1000;
      }
      .skip-link:focus {
        transform: translateY(0);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </head>

  <body>
    <div class="reading-progress" id="progress-bar" aria-hidden="true"></div>

    <a class="skip-link" href="#main">
      {isEnglish ? 'Skip to content' : 'Pular para o conteúdo'}
    </a>

    <div class="shell">
      <header class="topbar">
        <NavBar lang={lang} currentState="writing" />
        <a class="lang" href={langSwitchHref} hreflang={isEnglish ? 'pt-br' : 'en'}>
          <span aria-hidden="true">/</span> {langSwitchLabel}
        </a>
      </header>

      <main id="main" class="main">
      <article class="post">
        <header class="post-head">
          <div class="meta">
            <time datetime={frontmatter.date}>{formattedDate}</time>
            <span class="sep" aria-hidden="true">·</span>
            <span>{totalTime}</span>
          </div>

          <h1>{frontmatter.title}</h1>

          {frontmatter.description && (
            <p class="dek">{frontmatter.description}</p>
          )}

          <div class="rule" aria-hidden="true">
            <span class="rule-line"></span>
            <span class="rule-dot"></span>
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        <footer class="post-foot">
          <a class="back" href={indexHref}>
            <span aria-hidden="true">←</span> {backLabel}
          </a>
        </footer>
      </article>
      </main>

      <footer class="foot">
        <span>© {new Date().getFullYear()} Diel Duarte</span>
        <span class="foot-sep" aria-hidden="true">·</span>
        <span>{isEnglish ? 'the whole thing is a tree' : 'o site inteiro é uma árvore'}</span>
      </footer>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const progressBar = document.getElementById('progress-bar');
        const article = document.querySelector('article');
        if (!progressBar || !article) return;

        const update = () => {
          const scrollTop = window.scrollY;
          const docHeight =
            (article as HTMLElement).offsetHeight +
            (article as HTMLElement).offsetTop -
            window.innerHeight;
          const progress = Math.min(Math.max(scrollTop / docHeight, 0), 1);
          (progressBar as HTMLElement).style.transform = `scaleX(${progress})`;
        };

        window.addEventListener('scroll', update, { passive: true });
        update();
      });
    </script>

    <style>
      .shell {
        max-width: 920px;
        margin: 0 auto;
        padding: var(--s-5) var(--s-5) var(--s-6);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.04em;
        color: var(--n-5);
        padding-bottom: var(--s-5);
        gap: var(--s-4);
        flex-wrap: wrap;
      }

      .lang {
        color: var(--n-5);
        transition: color var(--t-3) var(--ease);
      }

      .lang:hover { color: var(--n-7); }
      .lang:active { transform: scale(0.97); }

      .main {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .post {
        padding: var(--s-5) 0 var(--s-6);
      }

      .post-head {
        margin-bottom: var(--s-6);
        max-width: 62ch;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--s-3);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.04em;
        color: var(--accent);
        margin-bottom: var(--s-4);
      }

      .meta .sep { color: var(--n-4); }
      .meta span:last-child { color: var(--n-5); }

      .post-head h1 {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.5vw + 0.5rem, var(--fs-3xl));
        line-height: 1.02;
        letter-spacing: -0.03em;
        color: var(--n-7);
        margin: 0 0 var(--s-4) 0;
        font-weight: 600;
      }

      .dek {
        font-size: var(--fs-md);
        line-height: var(--lh-read);
        color: var(--n-5);
        margin: 0;
        max-width: 58ch;
      }

      .rule {
        margin-top: var(--s-5);
        display: flex;
        align-items: center;
        gap: var(--s-2);
      }

      .rule-line {
        width: 48px;
        height: 1px;
        background: var(--accent);
      }

      .rule-dot {
        width: 6px;
        height: 6px;
        border-radius: var(--r-full);
        background: var(--accent);
      }

      .post-foot {
        margin-top: var(--s-6);
        padding-top: var(--s-5);
        border-top: 1px dashed var(--n-3);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--s-4);
      }

      .back {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        font-family: var(--font-mono);
        font-size: var(--fs-sm);
        color: var(--n-5);
        padding: var(--s-2) var(--s-3);
        border: 1px solid var(--n-3);
        border-radius: var(--r-md);
        transition:
          color var(--t-3) var(--ease),
          background-color var(--t-3) var(--ease),
          border-color var(--t-3) var(--ease),
          transform var(--t-2) var(--ease);
      }

      @media (hover: hover) and (pointer: fine) {
        .back:hover {
          color: var(--n-7);
          border-color: var(--accent);
          background: color-mix(in oklab, var(--accent) 8%, transparent);
        }
      }

      .back:active { transform: scale(0.97); }

      .foot {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        color: var(--n-5);
        padding-top: var(--s-5);
        border-top: 1px dashed var(--n-3);
      }

      .foot-sep { color: var(--n-4); }

      @media (max-width: 640px) {
        .shell { padding: var(--s-4) var(--s-4) var(--s-5); }
      }
    </style>
  </body>
</html>
